{
	"compilerOptions": {
		"strict": true,
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": ["./**/*.ts", "../src/lib/types.ts", "../src/lib/geo/**/*.ts"]
}
